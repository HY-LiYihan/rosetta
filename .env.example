# Runtime base directory. data/backups/logs will be created under this path.
ROSETTA_RUNTIME_DIR=/opt/rosetta/runtime

# Compose service/container settings
ROSETTA_CONTAINER=rosetta-app
ROSETTA_PORT=8501

# Optional overrides. Leave commented unless you need custom split paths.
# ROSETTA_DATA_DIR=/opt/rosetta/runtime/data
# ROSETTA_BACKUP_DIR=/opt/rosetta/runtime/backups
# ROSETTA_LOG_DIR=/opt/rosetta/runtime/logs
